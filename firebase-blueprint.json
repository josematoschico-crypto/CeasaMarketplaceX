{
  "entities": {
    "User": {
      "title": "User",
      "description": "A producer or buyer in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "role": { "type": "string", "enum": ["seller", "buyer"] },
        "barracaId": { "type": "string" }
      },
      "required": ["name", "whatsapp", "role"]
    },
    "Stall": {
      "title": "Stall",
      "description": "A stall in the CEASA market.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "StallProduct": {
      "title": "StallProduct",
      "description": "A product offered by a specific stall.",
      "type": "object",
      "properties": {
        "stallId": { "type": "string" },
        "productId": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["stallId", "productId", "price", "stock"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/stalls/{stallId}": {
      "schema": "Stall",
      "description": "Stall information."
    },
    "/stallProducts/{productId}": {
      "schema": "StallProduct",
      "description": "Products offered by stalls."
    }
  }
}
